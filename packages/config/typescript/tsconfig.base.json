{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "jsx": "preserve",

    "ignoreDeprecations": "5.0",

    "baseUrl": ".",
    "paths": {
      "@devfolio/config/*": ["../*"],
      "@devfolio/styles/*": ["../*"]
    }
  },
  "exclude": [
    "eslint.config.mjs", 
    "node_modules", 
    "dist", 
    "build",
    ".next",
    ".turbo",
    ".cache"
  ]
}
